% ==========================================================
% beamerinnerthemeMKA.sty
% ==========================================================

%\ProvidesPackage{beamerinnerthemeMKA}

% ==========================================================
% Grundlayout
% ==========================================================

\setbeamersize{
  text margin left=2em,
  text margin right=2em
}

\setbeamertemplate{navigation symbols}{}
% Weniger Abstand in inneren itemize-Listen
%\setbeamertemplate{itemize/enumerate body begin level 2}{\vspace{-5pt}}

% ----------------------------------------------------------
% Frame title (kompakt)
% ----------------------------------------------------------
\setbeamertemplate{frametitle}{
  \vspace{0.8em}
  {\usebeamerfont{frametitle}\bfseries\insertframetitle\par}
  \vspace{-0.4em}
}

% ----------------------------------------------------------
% Footline (minimal, ruhig)
% ----------------------------------------------------------
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth,ht=2.4em,dp=1em,leftskip=2em,rightskip=2em]{footlinecolor}
    \hfill\scriptsize\insertframenumber
  \end{beamercolorbox}
}

% ==========================================================
% Inhaltsverzeichnis
% ==========================================================

\setbeamertemplate{section in toc}[sections unnumbered]
\setbeamertemplate{subsection in toc}{
  \leavevmode
  \leftskip=3em
  \inserttocsubsection\par
}
\setbeamertemplate{subsubsection in toc}{
  \leavevmode
  \leftskip=5em
  \inserttocsubsubsection\par
}

% ==========================================================
% Schrift
% ==========================================================

\setsansfont{Epilogue}[%
  Path=./theme/epilogueFont/,
  Scale=0.9,
  Extension=.ttf,
  UprightFont=*-Regular,
  BoldFont=*-Bold,
  ItalicFont=*-Italic,
  BoldItalicFont=*-BoldItalic,
  Language=German,
  HyphenRules=German
]


% ==========================================================
% Section / Subsection / Subsubsection Frames (make…page)
% ==========================================================

% ==============================
% Sectionpage mit optionalem Bild
% ==============================
\newcommand{\makesectionpage}[2][]{%
  \section{#2}%  % <-- WICHTIG: Zähler zuerst setzen
  {
    \setbeamercolor{background canvas}{bg=BlockBackground!50!White}
    
    \begin{frame}[plain]
      \setbeamertemplate{footline}{}
      
      \begin{columns}[T, totalwidth=\textwidth]
        \begin{column}{0.35\textwidth}
          \ifx&#1&%
          \else
            \centering
            \hspace*{-8mm}
            \vspace*{-2.2mm}
            \includegraphics[height=\paperheight,keepaspectratio]{#1}
          \fi
        \end{column}

        \begin{column}{0.65\textwidth}
          \vspace{5cm} 
          \centering
          {\usebeamerfont{title}\usebeamercolor[fg]{frametitle}\Huge
            #2\par}
        \end{column}
      \end{columns}
      
      \setbeamertemplate{footline}[default]
    \end{frame}
  }
}

% ==============================
% Subsectionpage mit optionalem Untertitel
% ==============================
\newcommand{\makesubsectionpage}[2][]{%
  \subsection{#2}%
  {
    \begin{frame}[plain]
      \setbeamertemplate{footline}{}
      
      \vspace{4cm}
      \centering
      {\usebeamerfont{title}\usebeamercolor[fg]{frametitle}\Huge
        #2\par}

      \ifx&#1&%
      \else
        \vspace{0.5cm}
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{frametitle}\Large #1\par}
      \fi

      \setbeamertemplate{footline}[default]
    \end{frame}
  }
}

% ==========================================================
% Subsubsectionpage (ohne Untertitel, Beamer-sicher)
% ==========================================================
\makeatletter
\providecommand{\makesubsubsectionpage}[1]{%
  \subsubsection{#1}%  % <-- Zähler & TOC korrekt von Beamer

  \begin{frame}[plain]
    \setbeamertemplate{footline}{}

    \vspace{4cm}
    \centering
    {\usebeamerfont{title}%
     \usebeamercolor[fg]{frametitle}%
     \Huge
     #1\par}

    \setbeamertemplate{footline}[default]
  \end{frame}
}
\makeatother


%%%%%%%%%%%%%%%% Sction ohne nummerierung
\newcommand{\makesectionpageunnum}[2][]{%
  \section*{#2}%
  \addcontentsline{toc}{section}{#2}% optional fürs Inhaltsverzeichnis
  {
    \setbeamercolor{background canvas}{bg=BlockBackground!50!White}
    
    \begin{frame}[plain]
      \setbeamertemplate{footline}{}
      
      \begin{columns}[T, totalwidth=\textwidth]
        \begin{column}{0.35\textwidth}
          \ifx&#1&%
          \else
            \centering
            \hspace*{-8mm}
            \vspace*{-2.2mm}
            \includegraphics[height=\paperheight,keepaspectratio]{#1}
          \fi
        \end{column}

        \begin{column}{0.65\textwidth}
          \vspace{5cm} 
          \centering
          {\usebeamerfont{title}\usebeamercolor[fg]{frametitle}\Huge
            #2\par}
        \end{column}
      \end{columns}
      
      \setbeamertemplate{footline}[default]
    \end{frame}
  }
}

% ==========================================================
% Image + Title Frame
% ==========================================================
\newcommand{\TitelFrame}[1][\TITLEIMAGE]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture,overlay]

      % Hintergrundbild
      \node[anchor=center,inner sep=0] at (current page.center) {
        \includegraphics[width=\paperwidth,keepaspectratio=true]{#1}
      };

      % Transparenter Balken
      \fill[black,opacity=0.65]
        (current page.south west)
        rectangle
        ([yshift=3.8cm]current page.south east);

      % Text: MINIPAGE LIEGT IM BALKEN
      \node[
        anchor=west,
        inner sep=0pt
      ] at ([xshift=0.05\paperwidth,yshift=1.9cm]current page.south west) {%
        \begin{minipage}[c]{0.7\paperwidth}
          \raggedright
          \color{white}

          {\Huge\bfseries \inserttitle\par}
          \vspace{0.4em}
          {\Large \insertsubtitle\par}
          \vspace{0.4em}
          {\normalsize \insertauthor}

        \end{minipage}
      };

    \end{tikzpicture}
  \end{frame}
}

% ==========================================================
% Quellenangabe unten links
% ==========================================================
\newlength{\sourceboxwidth}
\setlength{\sourceboxwidth}{0.42\paperwidth}

\newcommand{\source}[1]{%
  \begin{textblock*}{\sourceboxwidth}(2em,1.03\textheight)
    \raggedright\tiny #1
  \end{textblock*}
}

% ==========================================================
% Block-Stile
% ==========================================================
%\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamertemplate{blocks}[default]



\newenvironment{blockC1}[1]{%
  \setbeamercolor{block title}{bg=SecondaryTitle,fg=White}
  \setbeamercolor{block body}{bg=BlockBackground,fg=TextColor}
  \begin{block}{#1}}{\end{block}}

\newenvironment{blockC2}[1]{%
  \setbeamercolor{block title}{bg=AlertTitle,fg=White}
  \setbeamercolor{block body}{bg=BlockBackground,fg=TextColor}
  \begin{block}{#1}}{\end{block}}

\newenvironment{blockC3}[1]{%
  \setbeamercolor{block title}{bg=AccentTitle,fg=White}
  \setbeamercolor{block body}{bg=BlockBackground,fg=TextColor}
  \begin{block}{#1}}{\end{block}}

\newenvironment{blockC4}[1]{%
  \setbeamercolor{block title}{bg=ExampleTitle,fg=White}
  \setbeamercolor{block body}{bg=BlockBackground,fg=TextColor}
  \begin{block}{#1}}{\end{block}}

\newenvironment{blockDef}[1]{%
  \begin{blockC3}{#1}}{\end{blockC3}}

  \newenvironment{blockExample}[1]{%
  \begin{blockC4}{#1}}{\end{blockC4}}



 % ==========================================================
% Getrennte Zähler für mathematische Umgebungen
% Nummerierung: section.subsection.<laufend>
% ==========================================================

\newcounter{definitionctr}[subsection]
\newcounter{lemmactr}[subsection]
\newcounter{satzctr}[subsection]
\newcounter{korollarctr}[subsection]
\newcounter{beispielctr}[subsection]

\renewcommand{\thedefinitionctr}{\thesection.\thesubsection.\arabic{definitionctr}}
\renewcommand{\thelemmactr}{\thesection.\thesubsection.\arabic{lemmactr}}
\renewcommand{\thesatzctr}{\thesection.\thesubsection.\arabic{satzctr}}
\renewcommand{\thekorollarctr}{\thesection.\thesubsection.\arabic{korollarctr}}
\renewcommand{\thebeispielctr}{\thesection.\thesubsection.\arabic{beispielctr}}

\renewenvironment{definition}[1][]{
  \refstepcounter{definitionctr}
  \begin{blockDef}{Definition \thedefinitionctr%
    \ifx&#1&\else\ (#1)\fi}
}{
  \end{blockDef}
}

\renewenvironment{lemma}[1][]{
  \refstepcounter{lemmactr}
  \begin{block}{Lemma \thelemmactr%
    \ifx&#1&\else\ (#1)\fi}
}{
  \end{block}
}

\renewenvironment{satz}[1][]{
  \refstepcounter{satzctr}
  \begin{block}{Satz \thesatzctr%
    \ifx&#1&\else\ (#1)\fi}
}{
  \end{block}
}

\newenvironment{beispiel}[1][]{
  \refstepcounter{beispielctr}
  \begin{blockExample}{Beispiel \thebeispielctr%
    \ifx&#1&\else\ (#1)\fi}
}{
  \end{blockExample}
}

% ==========================================================
% Terminal Block
% ==========================================================
\definecolor{terminalbg}{RGB}{20,20,20}
\definecolor{terminalfg}{RGB}{0,220,0}

\newenvironment{terminalbox}[1]{%
  \setbeamercolor{block title}{fg=white,bg=black}
  \setbeamercolor{block body}{fg=terminalfg,bg=terminalbg}
  \begin{block}{#1}\ttfamily}{\end{block}}

% ==========================================================
% Itemize: 3 Quadrate
% ==========================================================
\setbeamertemplate{itemize item}{%
  \tikz{
    \fill[fill=structure.fg, draw=none] (0,0) rectangle (0.1,0.1);
    \fill[fill=structure.fg, draw=none] (0.1,0.1) rectangle (0.2,0.2);
    \fill[fill=structure.fg, draw=none] (0,0.2) rectangle (0.1,0.3);
  }
}
\setbeamertemplate{itemize subitem}{%
  \tikz{
    \fill[fill=structure.fg, draw=none] (0,0) rectangle (0.075,0.075);
    \fill[fill=structure.fg, draw=none] (0.075,0.075) rectangle (0.15,0.15);
    \fill[fill=structure.fg, draw=none] (0,0.15) rectangle (0.075,0.225);
  }
}
\setbeamertemplate{itemize subsubitem}{%
  \tikz{
    \fill[fill=structure.fg, draw=none] (0.05,0.05) rectangle (0.15,0.15);
  }
}

% Enumeration-Nummern fett
\setbeamertemplate{enumerate items}[default]
\setbeamerfont{enumerate item}{series=\bfseries}
\setbeamerfont{enumerate subitem}{series=\bfseries}
\setbeamerfont{enumerate subsubitem}{series=\bfseries}



% ==========================================================
% Hilfsfolie: Karomuster
% ==========================================================
\newcommand{\karogrid}{%
  \begin{tikzpicture}[remember picture,overlay]%
    \draw[step=0.5cm,gray!35,very thin] (current page.south west) grid (current page.north east);%
  \end{tikzpicture}%
}

% Beispiel: Karo-Folie ohne Parameter
\newcommand{\KaroFolie}{%
  \begin{frame}[plain]%
    \karogrid%
  \end{frame}%
}

% ----------------------------------------------------------
% Frageseite
\newcommand{\makequestionspage}[1]{%
  {%
    \setbeamertemplate{background canvas}{%
      \hspace*{\paperwidth-\paperheight}
      \includegraphics[height=\paperheight,keepaspectratio]{#1}%
    }%
    \begin{frame}[plain]
      \begin{columns}
        % Linke Spalte mit Text
        \begin{column}[T]{0.35\textwidth}
          %
          \vspace{2cm}
          {\usebeamerfont{title}\usebeamercolor[fg]{frametitle}\Huge Fragen?\par}
        \end{column}
        % Rechte Spalte leer
        \begin{column}[T]{0.55\textwidth}
        \end{column}
      \end{columns}
    \end{frame}
  }%
}

% ----------------------------------------------------------
% Quizseite mit optionalem Titel (Standard: Quiz)
\newcommand{\makequizpage}[4][Quiz]{%
  {%
    \setbeamertemplate{background canvas}{%
      \includegraphics[height=\paperheight,keepaspectratio]{#4}%
    }%
    \begin{frame}
      \begin{columns}
        \begin{column}{0.4\textwidth}
        \end{column}
        \begin{column}{0.55\textwidth}
          \vspace{0.5cm}
          {\usebeamerfont{title}\usebeamercolor[fg]{frametitle}\Huge #1\par}
          \vspace{0.5cm}
          \centering
          \includegraphics[width=0.6\linewidth]{#3}
          {\Large \url{#2}\par}
        \end{column}
      \end{columns}
    \end{frame}
  }%
}

% ==========================================================
% Titel-Inhalt-Frame
% #1 = Titel
% #2 = Inhalt
% ==========================================================
\newcommand{\maketitlecontentframe}[2]{%
  \begin{frame}
    \begin{columns}[T, totalwidth=\textwidth]
      
      % --------------------------------
      % Linke Spalte: Titel (33 %)
      % --------------------------------
      \begin{column}{0.25\textwidth}
        \vspace{2.5cm} % vertikale Absenkung des Titels
        {\usebeamerfont{frametitle}%
         \usebeamercolor[fg]{frametitle}%
          #1\par}
      \end{column}
      
      % --------------------------------
      % Rechte Spalte: Inhalt (66 %)
      % --------------------------------
      \begin{column}{0.66\textwidth}
        #2
      \end{column}
      
    \end{columns}
  \end{frame}
}