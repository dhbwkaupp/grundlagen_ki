% ================================
% Farben - abgestimmt auf Twemoji
% (Twitter/X Emoji Farbwelt)
% ================================

\definecolor{PrimaryColor}{HTML}{226699}      % RGB 34,102,153
\definecolor{SecondaryColor}{HTML}{55ACEE}    % RGB 85,172,238
\definecolor{ThirdColor}{HTML}{8A4FFF}       % RGB 138,79,255

\definecolor{AccentColor}{HTML}{FFAC33}       % RGB 255,172,51
\definecolor{ExampleColor}{HTML}{78B159}      % RGB 120,177,89
\definecolor{AlertColor}{HTML}{D84A62}        % RGB 216,74,98

\definecolor{TextColor}{HTML}{1E1E1E}          % RGB 30,30,30
\definecolor{DarkGrey}{HTML}{606060}           % RGB 96,96,96

\definecolor{BlockBackground}{HTML}{EBF7FF}   % RGB 235,247,255
%\definecolor{BackgroundColor}{HTML}{FDFEFF}   % RGB 253,254,255
\definecolor{BackgroundColor}{HTML}{FFFFFF}   % RGB 253,254,255

\definecolor{White}{HTML}{FFFFFF}              % RGB 255,255,255

% ================================
% Kontrastoptimierte Blocktitel-Farben

\definecolor{PrimaryTitle}{HTML}{194C73}       % RGB 25,76,115
\definecolor{SecondaryTitle}{HTML}{2D7DBE}     % RGB 45,125,190
\definecolor{AccentTitle}{HTML}{D25F14}        % RGB 210,95,20
\definecolor{ExampleTitle}{HTML}{558C41}       % RGB 85,140,65
\definecolor{AlertTitle}{HTML}{A0041E}         % RGB 160,4,30     % 
\definecolor{ThirdTitle}{HTML}{6430C4}    % RGB 100,48,196

% ================================
% Struktur-Farben
% ================================
\usecolortheme[named=PrimaryColor]{structure}
\setbeamercolor{titlelike}{parent=structure}

% ================================
% Hintergrund & Text
% ================================
\setbeamercolor{background canvas}{bg=BackgroundColor}
\setbeamercolor{normal text}{fg=TextColor, bg=BackgroundColor}

% ================================
% Folienüberschriften
% ================================
\setbeamercolor{frametitle}{fg=TextColor, bg=PrimaryColor}         % Dunkelgrau auf Primärblau
\setbeamercolor{framesubtitle}{fg=TextColor, bg=PrimaryColor}     % Dunkelgrau auf Primärblau
\setbeamercolor{section in toc}{fg=TextColor}                      % Abschnittstitel dunkel
\setbeamercolor{subsection in toc}{fg=TextColor}                   % Unterabschnittstitel dunkel

% ================================
% Listenpunkte
% ================================
%\setbeamercolor{item}{fg=SecondaryColor}

% ================================
% Block-Farben
% ================================
\setbeamercolor{block title}{bg=PrimaryTitle, fg=White}
\setbeamercolor{block body}{bg=BlockBackground, fg=TextColor}

\setbeamercolor{block title example}{bg=ExampleTitle, fg=White}
\setbeamercolor{block body example}{bg=BlockBackground, fg=TextColor}

\setbeamercolor{block title alerted}{bg=AccentTitle, fg=White}
\setbeamercolor{block body alerted}{bg=BlockBackground, fg=TextColor}

\setbeamercolor{block title example}{bg=ExampleTitle, fg=White}
\setbeamercolor{block body example}{bg=BlockBackground, fg=TextColor}


% ================================
% Fußzeile
% ================================
\setbeamercolor{footlinecolor}{fg=DarkGrey}

% ================================
% Hervorgehobener Text
% ================================
\setbeamercolor{alerted text}{fg=AlertColor}
\setbeamercolor{example text}{fg=ExampleColor}

% ================================
% Tabellenanpassungen
% ================================
\newcommand{\headerrowcolor}{\rowcolor{PrimaryColor}}
\newcommand{\headerfont}{\color{White}\bfseries}
\newcommand{\tablerowcolorone}{\rowcolor{SecondaryColor!20}}
\newcommand{\tablerowcolortwo}{\rowcolor{BackgroundColor}}


% ================================
% Farben für Algorithmen
% ================================
\colorlet{TableRowColLight}{SecondaryColor!20}
\colorlet{TableRowColDark}{BackgroundColor}

\colorlet{CurrentItemColor}{AccentTitle!82}     % Hintergrund-Farbe aktuelles Element
\colorlet{CurrentItemTextColor}{White}   % Text-Farbe aktuelles Element
\colorlet{CurrentItemColorDark}{AccentTitle!70!Black} % Alternativ: Dunkler Hintergrund aktuelles Element
\colorlet{CurrentItemColorTextDark}{White}   % Textfarbe für Dunkler Hintergrund aktuelles Element
\colorlet{CurrentItemHighlightColor}{AccentTitle}   % Farbe für aktuelle Elemente ohne Text (z.~B. Graphkanten)
\colorlet{ProcessedItemsColor}{SecondaryColor!22} % Hintergrund bearbeitete Elemente
\colorlet{ProcessedItemsTextColor}{TextColor}  % Text Bearbeitete Elemente
\colorlet{VertexColor}{DarkGrey!20}     % Knoten in Graphen

